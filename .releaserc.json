{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "task version:set VERSION=${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "dist/release/kiro-krew-linux-amd64",
            "label": "kiro-krew Linux AMD64"
          },
          {
            "path": "dist/release/kiro-krew-macos-arm64", 
            "label": "kiro-krew macOS ARM64"
          },
          {
            "path": "dist/release/kiro-krew-windows-amd64.exe",
            "label": "kiro-krew Windows AMD64"
          }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "internal/version/version.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}